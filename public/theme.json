{
  "name": "theme-anheyu-next",
  "displayName": "Next 主题",
  "version": "1.0.0",
  "description": "一个现代化的博客主题，基于 Next.js 和 HeroUI 构建，采用 anheyu-pro 配色方案",
  "author": "安知鱼",
  "homepage": "https://anheyu.com",
  "license": "MIT",
  "preview": "/static/img/preview.png",
  "config": {
    "appearance": {
      "themeColor": "#163bf2",
      "defaultTheme": "system",
      "enableAnimation": true,
      "enableParallax": true
    },
    "layout": {
      "sidebarPosition": "right",
      "postsPerPage": 10,
      "showTOC": true
    },
    "footer": {
      "startYear": 2020,
      "customHtml": ""
    },
    "features": {
      "enableSearch": true,
      "enableComments": true,
      "enableDarkMode": true
    }
  }
}
